# GPT-5.4 CONFIGURATION [cite: 32, 39]
VITE_GPT_ENDPOINT=https://nexalaris-tech.openai.azure.com/openai/deployments/gpt-5.4/chat/completions?api-version=2024-10-21

# BROWSER API CONFIGURATION
VITE_ENABLE_WEB_SPEECH_API=false # Set to false to use the high-fidelity Nexalaris TTS instead [cite: 10]
VITE_ENABLE_SPEECH_RECOGNITION=true
# IMAGE GENERATION & VISION DEPLOYMENT [NEW]
# GPT-image-1.5 can generate images and analyze images (vision tasks)
VITE_IMAGE_ENDPOINT=https://nexalaris-tech.openai.azure.com/openai/deployments/gpt-image-1.5/generations?api-version=2024-10-21
VITE_VISION_ENDPOINT=https://nexalaris-tech.openai.azure.com/openai/deployments/gpt-image-1.5/chat/completions?api-version=2024-10-21

# Strict Rate Limit for Images (3 requests per minute)
# To stay under rate limits, minimum 20 seconds between image requests is enforced
VITE_IMAGE_RPM_LIMIT=3
VITE_IMAGE_MIN_INTERVAL_SECONDS=20
