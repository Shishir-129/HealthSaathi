# Text-to-Speech Configuration
# Optional: If you want to use an external TTS API (like Google Cloud TTS, Azure Speech, etc.)
# Leave empty to use only the browser's Web Speech API (no keys needed)

# External TTS API Key (optional - use only if implementing premium TTS)
# VITE_TTS_API_KEY=your_api_key_here

# External TTS API Endpoint (optional - use only with TTS_API_KEY)
# VITE_TTS_API_ENDPOINT=https://api.example.com/tts

# Feature Flags
VITE_ENABLE_VOICE=true
VITE_ENABLE_LOGS=true
